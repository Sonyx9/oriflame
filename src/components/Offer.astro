---
const items = [
  {
    title: 'Osobní konzultace',
    text: 'Nezávazně projdeme, co řešíte — pleť, rutinu, barvy nebo třeba návrat k péči po náročném období.',
    icon: 'chat',
  },
  {
    title: 'Doporučení na míru',
    text: 'Žádné univerzální rady. Společně vybereme směr, který dává smysl vaší pleti i vašemu kalendáři.',
    icon: 'sparkle',
  },
  {
    title: 'Dlouhodobá podpora',
    text: 'Můžete se ozvat, když se něco změní — roční období, stres, nová péče. Jsem tu jako stabilní kontakt.',
    icon: 'heart',
  },
];
---
<section id="nabidka" class="scroll-mt-28 bg-[#E8B4B7]/18 py-16 md:py-24">
  <div class="container-page">
    <div class="mx-auto max-w-4xl text-center lg:max-w-5xl">
      <p class="text-[12px] font-medium tracking-[0.02em] text-[#D4AF37]">Pojďte do toho se mnou</p>
      <h2
        class="mt-3 text-[2rem] font-semibold tracking-tight text-[#2c2825] md:text-[2.35rem]"
        style="font-family: var(--font-serif);"
      >
        Co pro vás můžu udělat
      </h2>
      <p class="mt-4 text-[15px] leading-relaxed text-[#6b6560]">
        Prezentace bez „vitríny“ — zaměřujeme se na vztah a srozumitelnost, ne na seznam produktů na stránce.
      </p>
    </div>

    <div class="mt-14 grid gap-6 md:grid-cols-3">
      {items.map((item) => (
        <article
          class="flex flex-col rounded-[1.25rem] border border-[#E8B4B7]/40 bg-[#fffcfa] p-8 shadow-[0_4px_24px_rgba(44,40,37,0.04)] transition hover:shadow-[0_12px_40px_rgba(44,40,37,0.08)]"
        >
          <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-full bg-[#E8B4B7]/50 text-[#b8941f]">
            {item.icon === 'chat' && (
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8.625 12a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H8.25m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H12m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 01-2.555-.337A5.972 5.972 0 015.41 20.97a5.969 5.969 0 01-.474-.065 4.48 4.48 0 00.978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25z" />
              </svg>
            )}
            {item.icon === 'sparkle' && (
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 00-2.456 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 001.423 1.423l1.183.394-1.183.394a2.25 2.25 0 00-1.423 1.423z" />
              </svg>
            )}
            {item.icon === 'heart' && (
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" />
              </svg>
            )}
          </div>
          <h3 class="text-[1.15rem] font-medium text-[#2c2825]">{item.title}</h3>
          <p class="mt-3 flex-1 text-[14px] leading-relaxed text-[#6b6560]">{item.text}</p>
        </article>
      ))}
    </div>
  </div>
</section>
